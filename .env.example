# Flask
SECRET_KEY=change-this-to-a-random-secret-string
FLASK_DEBUG=1

# Database
# Default (works instantly, no setup): SQLite
DATABASE_URL=sqlite:///medtriage.db
# Postgres example (uncomment and edit to use Postgres instead):
# DATABASE_URL=postgresql://username:password@localhost:5432/medtriage

# No API key needed anywhere in this app — summaries are generated
# entirely offline by a rule-based engine (see llm_service.py).
